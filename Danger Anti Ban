-- ═══════════════════════════════════════════════════════════════
-- PROTEÇÃO 7: NETWORK OWNERSHIP (Otimizado)
-- ═══════════════════════════════════════════════════════════════
player.CharacterAdded:Connect(function(character)
	task.wait(2)
	SafePcall(function()
		for _, part in pairs(character:GetDescendants()) do
			if part:IsA("BasePart") and part:CanSetNetworkOwnership() then
				SafePcall(function()
					part:SetNetworkOwner(player)
				end)
			end
		end
	end)
end)

Log("✓ Network Ownership ativo")

-- ═══════════════════════════════════════════════════════════════
-- PROTEÇÃO 8: INPUT SIMULATOR (Micro-otimizado)
-- ═══════════════════════════════════════════════════════════════
task.spawn(function()
	while task.wait(0.5) do
		SafePcall(function()
			UpdateCache()
			if not Cache.Humanoid or not Cache.HRP then return end
			
			if Cache.HRP.Velocity.Magnitude > 40 and 
			   Cache.Humanoid.MoveVector.Magnitude < 0.1 then
				Cache.Humanoid:Move(Cache.HRP.Velocity.Unit * 0.001)
			end
		end)
	end
end)

Log("✓ Input Simulator ativo")

-- ═══════════════════════════════════════════════════════════════
-- PROTEÇÃO 9: WORKSPACE CLEANER (Otimizado)
-- ═══════════════════════════════════════════════════════════════
workspace.ChildAdded:Connect(function(child)
	SafePcall(function()
		local name = child.Name:lower()
		if name:find("anticheat") or name:find("detector") then
			child.Name = "Part" .. tostring(math.random(10000, 99999))
		end
	end)
end)

Log("✓ Workspace Cleaner ativo")

-- ═══════════════════════════════════════════════════════════════
-- PROTEÇÃO 10: CHARACTER INTEGRITY (Otimizado)
-- ═══════════════════════════════════════════════════════════════
player.CharacterAdded:Connect(function(character)
	task.wait(2)
	SafePcall(function()
		local parts = {"Head", "Torso", "HumanoidRootPart"}
		
		for _, partName in ipairs(parts) do
			if not character:FindFirstChild(partName) then
				local part = Instance.new("Part")
				part.Name = partName
				part.Size = Vector3.new(1, 1, 1)
				part.Transparency = 1
				part.CanCollide = false
				part.Parent = character
			end
		end
	end)
end)

Log("✓ Character Integrity ativo")

-- ═══════════════════════════════════════════════════════════════
-- SISTEMA DE CLEANUP (Gerenciamento de recursos)
-- ═══════════════════════════════════════════════════════════════
local connections = {}

local function Cleanup()
	for _, conn in pairs(connections) do
		if conn and conn.Connected then
			conn:Disconnect()
		end
	end
	connections = {}
	Cache = {}
	Log("Sistema limpo")
end

