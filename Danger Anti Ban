local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local player = Players.LocalPlayer

-- ═══════════════════════════════════════════════════════════════
-- CONFIGURAÇÕES (Personalizável para seu hub)
-- ═══════════════════════════════════════════════════════════════
local CONFIG = {
	EnableAntiKick = true,
	EnableACDestroyer = true,
	EnableRemoteBlock = true,
	EnableFlyBypass = true,
	EnableNormalizer = true,
	
	-- Timings otimizados
	CheckInterval = 5,        -- Verificações a cada 5s
	FlyCheckInterval = 2,     -- Fly check a cada 2s
	NormalizeInterval = 3,    -- Normalização a cada 3s
	
	-- Limites de detecção
	MaxSafeSpeed = 150,
	MaxSafeVelocity = 1000,
	MaxAirTime = 3,
	
	-- Debug
	DebugMode = false         -- true para ver logs
}

-- ═══════════════════════════════════════════════════════════════
-- SISTEMA DE CACHE (Otimização de performance)
-- ═══════════════════════════════════════════════════════════════
local Cache = {
	Character = nil,
	Humanoid = nil,
	HRP = nil,
	LastUpdate = 0
}

local function UpdateCache()
	local now = tick()
	if now - Cache.LastUpdate < 1 then return end
	
	Cache.Character = player.Character
	Cache.Humanoid = Cache.Character and Cache.Character:FindFirstChild("Humanoid")
	Cache.HRP = Cache.Character and Cache.Character:FindFirstChild("HumanoidRootPart")
	Cache.LastUpdate = now
end

-- ═══════════════════════════════════════════════════════════════
-- UTILIDADES
-- ═══════════════════════════════════════════════════════════════
local function SafePcall(func)
	local success, err = pcall(func)
	if not success and CONFIG.DebugMode then
		warn("[ANTI-BAN] Error:", err)
	end
	return success
end

local function Log(message)
	if CONFIG.DebugMode then
		print("[ANTI-BAN]", message)
	end
end

-- ═══════════════════════════════════════════════════════════════
-- PROTEÇÃO 1: ANTI-KICK OTIMIZADO
-- ═══════════════════════════════════════════════════════════════
if CONFIG.EnableAntiKick then
	-- Método 1: Proteção direta
	SafePcall(function()
		local oldKick = player.Kick
		player.Kick = function() 
			Log("Kick bloqueado (Método 1)")
			return 
		end
	end)
	
	-- Método 2: Hook de metatable (se suportado)
	SafePcall(function()
		if not hookmetamethod or not getnamecallmethod or not setreadonly then return end
		
		local mt = getrawmetatable(game)
		local oldNamecall = mt.__namecall
		
		setreadonly(mt, false)
		mt.__namecall = function(self, ...)
			if getnamecallmethod() == "Kick" and self == player then
				Log("Kick bloqueado (Método 2)")
				return
			end
			return oldNamecall(self, ...)
		end
		setreadonly(mt, true)
	end)
	
	Log("✓ Anti-Kick ativo")
end

-- ═══════════════════════════════════════════════════════════════
-- PROTEÇÃO 2: DESTRUIDOR DE ANTI-CHEAT (Otimizado)
-- ═══════════════════════════════════════════════════════════════
if CONFIG.EnableACDestroyer then
	local acNames = {"anticheat", "anti%-cheat", "antiexploit", "anti%-exploit"}
	local checkedScripts = {}
	
	local function DestroyAntiCheat()
		SafePcall(function()
			for _, descendant in pairs(game:GetDescendants()) do
				if (descendant:IsA("Script") or descendant:IsA("LocalScript")) and 
				   not checkedScripts[descendant] then
					
					checkedScripts[descendant] = true
					local name = descendant.Name:lower()
					
					for _, pattern in ipairs(acNames) do
						if name:match(pattern) then
							descendant.Disabled = true
							task.wait(0.05)
							descendant:Destroy()
							Log("Anti-cheat destruído: " .. descendant.Name)
							break
						end
					end
				end
			end
		end)
	end
	
	-- Executa uma vez no início
	DestroyAntiCheat()
	
	-- Loop otimizado
	task.spawn(function()
		while task.wait(CONFIG.CheckInterval) do
			DestroyAntiCheat()
		end
	end)
	
	Log("✓ AC Destroyer ativo")
end

-- ═══════════════════════════════════════════════════════════════
-- PROTEÇÃO 3: BLOQUEADOR DE REMOTES (Otimizado)
-- ═══════════════════════════════════════════════════════════════
if CONFIG.EnableRemoteBlock then
	SafePcall(function()
		if not hookmetamethod or not getnamecallmethod or not newcclosure then return end
		
		local blockedNames = {"ban", "kick"}
		local mt = getrawmetatable(game)
		local oldNamecall = mt.__namecall
		
		setreadonly(mt, false)
		mt.__namecall = newcclosure(function(self, ...)
			local method = getnamecallmethod()
			
			if method == "FireServer" or method == "InvokeServer" then
				local name = self.Name:lower()
				
				for _, blocked in ipairs(blockedNames) do
					if name:find(blocked) then
						Log("Remote bloqueado: " .. self.Name)
						return
					end
				end
			end
			
			return oldNamecall(self, ...)
		end)
		setreadonly(mt, true)
		
		Log("✓ Remote Blocker ativo")
	end)
end

-- ═══════════════════════════════════════════════════════════════
-- PROTEÇÃO 4: FLY BYPASS (Ultra Otimizado)
-- ═══════════════════════════════════════════════════════════════
if CONFIG.EnableFlyBypass then
	local lastGroundTouch = tick()
	
	task.spawn(function()
		while task.wait(CONFIG.FlyCheckInterval) do
			SafePcall(function()
				UpdateCache()
				if not Cache.Humanoid then return end
				
				local state = Cache.Humanoid:GetState()
				
				if state == Enum.HumanoidStateType.Freefall or 
				   state == Enum.HumanoidStateType.Flying then
					
					if tick() - lastGroundTouch > CONFIG.MaxAirTime then
						Cache.Humanoid:ChangeState(Enum.HumanoidStateType.Landed)
						task.wait(0.03)
						Cache.Humanoid:ChangeState(Enum.HumanoidStateType.Freefall)
						lastGroundTouch = tick()
					end
				else
					lastGroundTouch = tick()
				end
			end)
		end
	end)
	
	Log("✓ Fly Bypass ativo")
end

-- ═══════════════════════════════════════════════════════════════
-- PROTEÇÃO 5: NORMALIZADOR (Ultra Otimizado)
-- ═══════════════════════════════════════════════════════════════
if CONFIG.EnableNormalizer then
	task.spawn(function()
		while task.wait(CONFIG.NormalizeInterval) do
			SafePcall(function()
				UpdateCache()
				if not Cache.Humanoid or not Cache.HRP then return end
				
				-- Normaliza velocidade extrema
				if Cache.Humanoid.WalkSpeed > CONFIG.MaxSafeSpeed then
					local saved = Cache.Humanoid.WalkSpeed
					Cache.Humanoid.WalkSpeed = 16
					task.wait(0.3)
					Cache.Humanoid.WalkSpeed = saved
					Log("Velocidade normalizada")
				end
				
				-- Limita velocity extrema
				local vel = Cache.HRP.Velocity
				if vel.Magnitude > CONFIG.MaxSafeVelocity then
					Cache.HRP.Velocity = vel.Unit * CONFIG.MaxSafeVelocity
				end
			end)
		end
	end)
	
	Log("✓ Normalizer ativo")
end

