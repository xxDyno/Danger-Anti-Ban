		end)
	end,
	
	-- Cleanup para descarregar o sistema
	Cleanup = Cleanup,
	
	-- Status do sistema
	GetStatus = function()
		return {
			Active = true,
			AntiKick = CONFIG.EnableAntiKick,
			ACDestroyer = CONFIG.EnableACDestroyer,
			RemoteBlock = CONFIG.EnableRemoteBlock,
			FlyBypass = CONFIG.EnableFlyBypass,
			Normalizer = CONFIG.EnableNormalizer
		}
	end
}

